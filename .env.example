# Для трёх AI worker обязательны все 9 уникальных ключей.
# Worker 1: ключи 1-3
GEMINI_API_KEY=worker_1_key_1
GEMINI_API_KEY_2=worker_1_key_2
GEMINI_API_KEY_3=worker_1_key_3

# Worker 2: ключи 4-6
GEMINI_API_KEY_4=worker_2_key_1
GEMINI_API_KEY_5=worker_2_key_2
GEMINI_API_KEY_6=worker_2_key_3

# Worker 3: ключи 7-9
GEMINI_API_KEY_7=worker_3_key_1
GEMINI_API_KEY_8=worker_3_key_2
GEMINI_API_KEY_9=worker_3_key_3

# Можно переопределить при необходимости
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite
GEMINI_SPECS_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_CHUNK_SIZE=30
GEMINI_SPECS_CHUNK_SIZE=25
GEMINI_VISION_MAX_IMAGES=5
GEMINI_IMAGE_TIMEOUT=20
GEMINI_REQUEST_DELAY=1
# Количество полных проходов worker по своей группе из трёх ключей при 429.
GEMINI_MAX_RETRIES=3
