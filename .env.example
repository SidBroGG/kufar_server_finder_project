# Обязательно для команд analyze, run и vision
GEMINI_API_KEY=your_primary_api_key_here

# Необязательные резервные ключи. Пустые значения игнорируются.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Можно переопределить при необходимости
GEMINI_ANALYSIS_MODEL=gemini-3.1-flash-lite
GEMINI_SPECS_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_CHUNK_SIZE=30
GEMINI_SPECS_CHUNK_SIZE=25
GEMINI_VISION_MAX_IMAGES=5
GEMINI_IMAGE_TIMEOUT=20
GEMINI_REQUEST_DELAY=1
# Количество полных проходов по доступным ключам при ошибке 429
GEMINI_MAX_RETRIES=3
