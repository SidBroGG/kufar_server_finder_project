# Единственный API-ключ используется всеми AI worker.
GEMINI_API_KEY=your_gemini_api_key

# Количество параллельных AI worker. Каждый worker создаёт отдельный клиент,
# но все клиенты используют GEMINI_API_KEY.
GEMINI_WORKER_COUNT=3

# Необязательные настройки собственного Gemini endpoint/proxy.
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_API_VERSION=v1beta

GEMINI_ANALYSIS_MODEL=gemini-3.5-flash-lite
GEMINI_SPECS_MODEL=gemini-3.5-flash-lite
GEMINI_VISION_MODEL=gemini-3.5-flash-lite
GEMINI_CHUNK_SIZE=30
GEMINI_SPECS_CHUNK_SIZE=25
GEMINI_VISION_MAX_IMAGES=5
GEMINI_IMAGE_TIMEOUT=20
GEMINI_REQUEST_DELAY=1
# Максимальное количество попыток одного запроса, включая первую.
GEMINI_MAX_RETRIES=3
